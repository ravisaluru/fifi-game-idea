# Online play (optional). Copy to .env.local and fill in from your Firebase
# project console — Project settings → General → Your apps → Web app.
# Without these the game still works fully for solo + robots play;
# the "Play online" rooms simply show as unavailable.
#
# On Cloudflare Pages set these as build-time environment variables.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
